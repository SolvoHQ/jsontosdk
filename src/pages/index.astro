---
// jsontosdk — paste JSON → typed TS SDK
const sample = `{"id":1,"name":"Ada","posts":[{"title":"x"}]}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>jsontosdk — Paste JSON → Typed TS SDK</title>
    <meta
      name="description"
      content="Paste a JSON sample, get production-ready TypeScript interfaces + a Zod schema. No signup. Shareable URL."
    />
    <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Ctext y='.9em' font-size='90'%3E%E2%9A%A1%3C/text%3E%3C/svg%3E" />
    <script is:inline>
      window.va = window.va || function (...a) { (window.vaq = window.vaq || []).push(a); };
    </script>
    <script>
      import { inject } from '@vercel/analytics';
      inject();
    </script>
    <style>
      :root {
        --bg: #0d1117;
        --panel: #161b22;
        --panel-2: #1c2128;
        --border: #30363d;
        --fg: #e6edf3;
        --fg-dim: #8b949e;
        --accent: #f7df1e;
        --accent-fg: #0d1117;
        --code: #d2a8ff;
        --error: #f85149;
        --success: #3fb950;
      }
      * { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; }
      body {
        background: var(--bg);
        color: var(--fg);
        font: 14px/1.5 ui-monospace, SFMono-Regular, "SF Mono", Menlo, Consolas, monospace;
        min-height: 100vh;
      }
      .wrap { max-width: 1200px; margin: 0 auto; padding: 24px 20px 80px; }
      header { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 6px; flex-wrap: wrap; gap: 8px; }
      h1 {
        font-size: 22px;
        margin: 0;
        letter-spacing: -0.01em;
        font-weight: 700;
      }
      h1 .y { color: var(--accent); }
      .tag { color: var(--fg-dim); font-size: 13px; }
      .tag a { color: var(--fg-dim); border-bottom: 1px dotted var(--fg-dim); text-decoration: none; }
      .tag a:hover { color: var(--fg); }
      .pitch { color: var(--fg-dim); font-size: 13px; margin: 0 0 18px; }
      .row { display: grid; grid-template-columns: 1fr; gap: 12px; }
      @media (min-width: 900px) { .row { grid-template-columns: 1fr 1fr; } .row.input-row { grid-template-columns: 1fr; } }
      .panel { background: var(--panel); border: 1px solid var(--border); border-radius: 8px; overflow: hidden; }
      .panel-head {
        background: var(--panel-2);
        padding: 8px 12px;
        border-bottom: 1px solid var(--border);
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 12px;
        color: var(--fg-dim);
        text-transform: uppercase;
        letter-spacing: 0.08em;
      }
      .copy-btn {
        background: transparent;
        color: var(--fg-dim);
        border: 1px solid var(--border);
        padding: 3px 10px;
        font-size: 11px;
        font-family: inherit;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        cursor: pointer;
        border-radius: 4px;
      }
      .copy-btn:hover { color: var(--fg); border-color: var(--fg-dim); }
      .copy-btn.copied { color: var(--success); border-color: var(--success); }
      textarea, pre {
        margin: 0;
        padding: 14px;
        font: inherit;
        background: var(--panel);
        color: var(--fg);
        border: none;
        outline: none;
        width: 100%;
        resize: vertical;
      }
      textarea { min-height: 200px; }
      pre { min-height: 300px; max-height: 60vh; overflow: auto; white-space: pre; }
      .controls { display: flex; align-items: center; gap: 12px; margin: 12px 0 18px; flex-wrap: wrap; }
      button.generate {
        background: var(--accent);
        color: var(--accent-fg);
        border: none;
        padding: 10px 22px;
        font: inherit;
        font-weight: 700;
        font-size: 14px;
        cursor: pointer;
        border-radius: 6px;
        text-transform: uppercase;
        letter-spacing: 0.08em;
      }
      button.generate:hover:not(:disabled) { filter: brightness(1.1); }
      button.generate:disabled { opacity: 0.5; cursor: wait; }
      .status { color: var(--fg-dim); font-size: 12px; }
      .status.error { color: var(--error); }
      .ph { color: var(--fg-dim); font-style: italic; padding: 14px; }
      footer { margin-top: 32px; color: var(--fg-dim); font-size: 12px; text-align: center; }
      footer a { color: var(--fg-dim); }
      .kbd {
        background: var(--panel-2);
        border: 1px solid var(--border);
        padding: 1px 6px;
        border-radius: 3px;
        font-size: 11px;
      }
    </style>
  </head>
  <body>
    <div class="wrap">
      <header>
        <h1>jsonto<span class="y">sdk</span></h1>
        <div class="tag">
          <a href="https://github.com/SolvoHQ/jsontosdk" target="_blank" rel="noopener">github</a>
        </div>
      </header>
      <p class="pitch">
        Paste a JSON sample → TypeScript interfaces + Zod schema. LLM-named, no signup,
        URL is shareable. <span class="kbd">⌘</span>+<span class="kbd">Enter</span> to generate.
      </p>

      <div class="row input-row">
        <div class="panel">
          <div class="panel-head">
            <span>JSON sample</span>
            <span id="size" class="status"></span>
          </div>
          <textarea id="input" spellcheck="false" placeholder={sample}></textarea>
        </div>
      </div>

      <div class="controls">
        <button class="generate" id="gen" type="button">Generate</button>
        <span class="status" id="status">Up to 100 KB · 20 generations / hour / IP · free</span>
      </div>

      <div class="row">
        <div class="panel">
          <div class="panel-head">
            <span>types.ts</span>
            <button class="copy-btn" data-target="types-out" type="button">Copy</button>
          </div>
          <pre id="types-out"><span class="ph">// TypeScript interfaces will appear here</span></pre>
        </div>
        <div class="panel">
          <div class="panel-head">
            <span>schema.ts (zod)</span>
            <button class="copy-btn" data-target="schema-out" type="button">Copy</button>
          </div>
          <pre id="schema-out"><span class="ph">// Zod schema will appear here</span></pre>
        </div>
      </div>

      <footer>
        Free tool · <a href="https://github.com/SolvoHQ/jsontosdk" target="_blank" rel="noopener">source on GitHub</a> · feedback welcome
      </footer>
    </div>

    <script is:inline>
      (function () {
        const input = document.getElementById('input');
        const genBtn = document.getElementById('gen');
        const status = document.getElementById('status');
        const sizeEl = document.getElementById('size');
        const typesOut = document.getElementById('types-out');
        const schemaOut = document.getElementById('schema-out');
        const MAX_BYTES = 100 * 1024;

        function b64encode(s) {
          return btoa(unescape(encodeURIComponent(s))).replace(/\+/g, '-').replace(/\//g, '_').replace(/=+$/, '');
        }
        function b64decode(s) {
          s = s.replace(/-/g, '+').replace(/_/g, '/');
          while (s.length % 4) s += '=';
          try { return decodeURIComponent(escape(atob(s))); } catch (e) { return null; }
        }

        function renderSize() {
          const bytes = new TextEncoder().encode(input.value).length;
          sizeEl.textContent = bytes ? `${bytes.toLocaleString()} bytes` : '';
          sizeEl.classList.toggle('error', bytes > MAX_BYTES);
        }

        function setOutput(types, schema) {
          typesOut.textContent = types;
          schemaOut.textContent = schema;
        }

        async function generate() {
          const json = input.value.trim();
          if (!json) {
            status.textContent = 'Paste a JSON sample first.';
            status.classList.add('error');
            return;
          }
          const bytes = new TextEncoder().encode(json).length;
          if (bytes > MAX_BYTES) {
            status.textContent = `Input is ${bytes.toLocaleString()} bytes — max is ${MAX_BYTES.toLocaleString()}.`;
            status.classList.add('error');
            return;
          }
          try { JSON.parse(json); } catch (e) {
            status.textContent = 'That doesn’t parse as JSON: ' + e.message;
            status.classList.add('error');
            return;
          }

          genBtn.disabled = true;
          status.classList.remove('error');
          status.textContent = 'Generating…';
          const t0 = performance.now();
          try {
            const res = await fetch('/api/generate', {
              method: 'POST',
              headers: { 'content-type': 'application/json' },
              body: JSON.stringify({ json }),
            });
            const data = await res.json();
            if (!res.ok) {
              status.textContent = data.error || ('HTTP ' + res.status);
              status.classList.add('error');
              return;
            }
            setOutput(data.types || '', data.schema || '');
            const ms = Math.round(performance.now() - t0);
            status.textContent = `Generated in ${ms} ms.`;
            try {
              location.hash = 'payload=' + b64encode(json);
            } catch (e) { /* ignore */ }
            track('generate_click', { ms, bytes });
          } catch (e) {
            status.textContent = 'Network error: ' + e.message;
            status.classList.add('error');
          } finally {
            genBtn.disabled = false;
          }
        }

        function track(name, detail) {
          try { window.dispatchEvent(new CustomEvent('jsontosdk:' + name, { detail })); } catch (_) {}
          try { window.va && window.va('event', { name, data: detail }); } catch (_) {}
        }

        document.querySelectorAll('.copy-btn').forEach((btn) => {
          btn.addEventListener('click', async () => {
            const target = document.getElementById(btn.dataset.target);
            const text = target.textContent || '';
            if (!text || text.startsWith('// ')) return;
            try {
              await navigator.clipboard.writeText(text);
              const orig = btn.textContent;
              btn.textContent = 'Copied';
              btn.classList.add('copied');
              setTimeout(() => { btn.textContent = orig; btn.classList.remove('copied'); }, 1200);
            } catch (e) {
              btn.textContent = 'Copy failed';
            }
          });
        });

        input.addEventListener('input', renderSize);
        input.addEventListener('keydown', (e) => {
          if ((e.metaKey || e.ctrlKey) && e.key === 'Enter') {
            e.preventDefault();
            generate();
          }
        });
        genBtn.addEventListener('click', generate);

        // restore from URL fragment if present
        const hash = location.hash.replace(/^#/, '');
        const params = new URLSearchParams(hash);
        const payload = params.get('payload');
        if (payload) {
          const decoded = b64decode(payload);
          if (decoded) {
            input.value = decoded;
            renderSize();
            track('share_link_load', { bytes: new TextEncoder().encode(decoded).length });
            status.textContent = 'Loaded from URL. Press Generate to run.';
          }
        }
        renderSize();
      })();
    </script>
  </body>
</html>
